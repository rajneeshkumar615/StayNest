<% layout("layouts/boilerplate") %>

<div class="container py-3">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h4 class="mb-3 text-center">Create New Listing</h4>

      <form
        method="POST"
        action="/listings"
        novalidate
        class="needs-validation"
        enctype="multipart/form-data"
      >
        <div class="mb-2">
          <label class="form-label">Title</label>
          <input type="text" name="listing[title]" class="form-control form-control-sm" required />
          <div class="valid-feedback">Title looks good!</div>
        </div>

        <div class="mb-2">
          <label class="form-label">Description</label>
          <textarea
            name="listing[description]"
            rows="2"
            class="form-control form-control-sm"
            required
          ></textarea>
          <div class="invalid-feedback">please enter valid description</div>
        </div>

        <!-- ✅ Image URL Input -->
        <div class="mb-2">
          <label class="form-label">Upload Image</label>
          <input
            type="file"
            name="listing[image]"
            class="form-control form-control-sm"
            placeholder="enter image/URL here"
            accept="image/jpeg,image/png,image/gif,image/webp"
            required
          />
          <small class="text-muted d-block mt-1">
            ✅ Supported: JPG, PNG, GIF, WEBP | ❌ Not supported: HEIC, BMP
          </small>
        </div>

        <div class="row">
          <div class="col-4 mb-2">
            <label class="form-label">Price</label>
            <input
              type="number"
              name="listing[price]"
              class="form-control form-control-sm"
              required
            />
            <div class="invalid-feedback">please enter valid price</div>
          </div>

          <div class="col-8 mb-2">
            <label class="form-label">Country</label>
            <input
              type="text"
              name="listing[country]"
              class="form-control form-control-sm"
              required
            />
            <div class="invalid-feedback">please enter valid country name</div>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label">Location</label>
          <input
            type="text"
            name="listing[location]"
            class="form-control form-control-sm"
            required
          />
          <div class="invalid-feedback">please enter valid location</div>
        </div>

        <div class="mb-3">
          <label class="form-label">Category</label>
          <select name="listing[category]" class="form-control form-control-sm">
            <option value="Trending">Trending</option>
            <option value="Rooms">Rooms</option>
            <option value="Iconic Cities">Iconic Cities</option>
            <option value="Mountains">Mountains</option>
            <option value="Castles">Castles</option>
            <option value="Amazing pools">Amazing pools</option>
            <option value="Camping">Camping</option>
            <option value="Farms">Farms</option>
            <option value="Doms">Doms</option>
          </select>
        </div>

        <button class="btn btn-dark btn-sm">Add</button>
      </form>
    </div>
  </div>
</div>
